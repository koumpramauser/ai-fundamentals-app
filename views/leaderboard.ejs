<%- include('partials/header', { title: 'Leaderboard' }) %>
<%- include('partials/navbar') %>

<div class="page-sm">
  <div class="flex-between mb-3">
    <div>
      <div class="page-title">🏆 Leaderboard</div>
      <div class="page-sub">Top students ranked by total points earned across all topics.</div>
    </div>
    <a href="<%= sessionUser.role === 'admin' ? '/admin/dashboard' : '/student/dashboard' %>" class="btn btn-outline btn-sm">← Dashboard</a>
  </div>

  <!-- My Score -->
  <div class="card mb-3" style="background:var(--primary-lt);border-color:#93c5fd">
    <div class="flex-between">
      <div>
        <div style="font-weight:700;font-size:.95rem;color:var(--primary)">Your Score</div>
        <div class="text-muted" style="font-size:.85rem"><%= sessionUser.name %></div>
      </div>
      <div style="font-size:1.8rem;font-weight:800;color:var(--primary)">
        <%= myScore.total_points %> <span style="font-size:.85rem;font-weight:400">pts</span>
      </div>
    </div>
  </div>

  <div class="card">
    <% if (leaderboard.length === 0) { %>
      <p class="text-muted text-center" style="padding:2rem">No scores recorded yet. Start practicing!</p>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Student</th>
            <th>Points</th>
            <th>Last Active</th>
          </tr>
        </thead>
        <tbody>
          <% leaderboard.forEach((row, i) => { %>
          <tr style="<%= row.users?.id === sessionUser.id ? 'background:var(--primary-lt)' : '' %>">
            <td>
              <span class="lb-rank <%= i===0?'gold':i===1?'silver':i===2?'bronze':'' %>" style="font-size:1rem">
                <%= i===0 ? '🥇' : i===1 ? '🥈' : i===2 ? '🥉' : '#' + (i+1) %>
              </span>
            </td>
            <td>
              <strong><%= row.users?.name || 'Student' %></strong>
              <% if (row.users?.id === sessionUser.id) { %>
                <span class="tag tag-blue" style="margin-left:.4rem">You</span>
              <% } %>
            </td>
            <td><span class="lb-points"><%= row.total_points %></span></td>
            <td class="text-muted" style="font-size:.83rem">
              <%= row.last_updated ? new Date(row.last_updated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
