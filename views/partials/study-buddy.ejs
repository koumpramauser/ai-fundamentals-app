<!-- Study Buddy — floating AI chat sidebar -->
<div id="sb-toggle" onclick="toggleSB()" title="Study Buddy" style="
  position:fixed;bottom:24px;right:24px;z-index:9999;
  width:52px;height:52px;border-radius:50%;
  background:linear-gradient(135deg,#002F6C,#1a4d99);
  color:#fff;font-size:1.5rem;display:flex;align-items:center;justify-content:center;
  cursor:pointer;box-shadow:0 4px 16px rgba(0,47,108,.35);
  transition:transform .2s;user-select:none
" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">🤖</div>

<div id="sb-panel" style="
  position:fixed;bottom:88px;right:24px;z-index:9998;
  width:340px;max-height:480px;display:none;flex-direction:column;
  background:#fff;border-radius:16px;
  box-shadow:0 8px 32px rgba(0,47,108,.22);
  border:1px solid #d0d6e8;overflow:hidden;
">
  <!-- Header -->
  <div style="background:linear-gradient(90deg,#002F6C,#1a4d99);padding:.75rem 1rem;display:flex;align-items:center;justify-content:space-between">
    <div style="color:#fff;font-weight:700;font-size:.95rem">🤖 Study Buddy</div>
    <div style="color:rgba(255,255,255,.7);font-size:.78rem">Powered by Groq · Llama 3</div>
  </div>

  <!-- Messages -->
  <div id="sb-messages" style="flex:1;overflow-y:auto;padding:.75rem;display:flex;flex-direction:column;gap:.6rem;min-height:200px;max-height:300px">
    <div class="sb-msg sb-ai">👋 Hi! I'm your Study Buddy for AI Fundamentals at FAU. Ask me anything about the course topics!</div>
  </div>

  <!-- Input -->
  <div style="padding:.6rem;border-top:1px solid #ebeef6;display:flex;gap:.4rem">
    <input id="sb-input" type="text" placeholder="Ask a question..." style="
      flex:1;padding:.45rem .7rem;border:1.5px solid #d0d6e8;border-radius:8px;
      font-size:.87rem;outline:none;font-family:inherit
    " onkeydown="if(event.key==='Enter')sendSB()" />
    <button onclick="sendSB()" style="
      padding:.45rem .9rem;background:#002F6C;color:#fff;border:none;
      border-radius:8px;font-size:.87rem;cursor:pointer;font-weight:600
    ">Send</button>
  </div>
</div>

<style>
.sb-msg { padding:.55rem .75rem;border-radius:12px;font-size:.87rem;line-height:1.55;max-width:92%;word-break:break-word }
.sb-ai  { background:#f0f4ff;color:#0d1224;align-self:flex-start;border-bottom-left-radius:4px }
.sb-user{ background:#002F6C;color:#fff;align-self:flex-end;border-bottom-right-radius:4px }
.sb-typing { opacity:.6;font-style:italic }
</style>

<script>
function toggleSB() {
  const p = document.getElementById('sb-panel');
  p.style.display = p.style.display === 'flex' ? 'none' : 'flex';
  if (p.style.display === 'flex') document.getElementById('sb-input').focus();
}

async function sendSB() {
  const input = document.getElementById('sb-input');
  const msgs  = document.getElementById('sb-messages');
  const text  = input.value.trim();
  if (!text) return;
  input.value = '';

  // User bubble
  const userEl = document.createElement('div');
  userEl.className = 'sb-msg sb-user';
  userEl.textContent = text;
  msgs.appendChild(userEl);

  // Typing indicator
  const typingEl = document.createElement('div');
  typingEl.className = 'sb-msg sb-ai sb-typing';
  typingEl.textContent = '⏳ Thinking…';
  msgs.appendChild(typingEl);
  msgs.scrollTop = msgs.scrollHeight;

  try {
    const res = await fetch('/api/study-buddy', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text, context: document.title })
    });
    const data = await res.json();
    typingEl.className = 'sb-msg sb-ai';
    typingEl.textContent = data.reply || 'Sorry, I could not generate a response.';
  } catch (e) {
    typingEl.textContent = '⚠️ Connection error. Please try again.';
  }
  msgs.scrollTop = msgs.scrollHeight;
}
</script>
