      <% } %>
      <a href="/auth/logout" class="btn-logout">Log Out</a>
    <% } else { %>
      <a href="/auth/login" class="btn-logout">Login</a>
      <a href="/auth/register" class="btn-logout" style="background:rgba(255,255,255,.25)">Register</a>
    <% } %>
  </div>
</nav>
