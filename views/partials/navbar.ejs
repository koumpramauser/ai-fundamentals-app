<nav class="navbar">
  <a href="/student/dashboard" class="navbar-brand" style="display:flex;align-items:center;gap:.6rem">
    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b0/Siegel_der_Friedrich-Alexander-Universit%C3%A4t_Erlangen-N%C3%BCrnberg.svg/200px-Siegel_der_Friedrich-Alexander-Universit%C3%A4t_Erlangen-N%C3%BCrnberg.svg.png" alt="FAU" style="height:32px;width:32px;border-radius:50%;background:#fff;padding:1px" />
    Study<span>AI</span> &mdash; FAU
  </a>
  <div class="navbar-links">
    <a href="/student/dashboard">My Learning</a>
    <a href="/student/workspace">Workspace</a>
    <a href="/leaderboard">Leaderboard</a>
    <% if (sessionUser) { %>
      <span style="color:rgba(255,255,255,.6);font-size:.85rem">Hello, <%= sessionUser.name.split(' ')[0] %></span>
