<%- include('../partials/header', { title: 'Practice: ' + topic.title }) %>
<%- include('../partials/navbar') %>

<div class="page-sm">
  <div class="flex-between mb-3">
    <div>
      <div class="page-title">Practice: <%= topic.title %></div>
      <div class="page-sub">Answer all questions and submit. Open-ended answers are graded by AI.</div>
    </div>
    <a href="/student/topics/<%= topic.id %>" class="btn btn-outline btn-sm">← Topic</a>
  </div>

  <!-- Results summary -->
  <% if (results) { %>
  <div class="card mb-3 <%=
    totalEarned > 0
      ? (totalEarned >= questions.reduce((s,q)=>s+(q.points||10),0)*0.7 ? 'result-correct' : 'result-partial')
      : 'result-incorrect'
  %>">
    <div style="font-family:var(--font-head);font-size:1.1rem;font-weight:700;margin-bottom:.3rem">
      Session Score: <%= totalEarned %> / <%= questions.reduce((s,q)=>s+(q.points||10),0) %> points
    </div>
    <p style="font-size:.9rem">Your points have been added to your total. Keep practicing!</p>
    <a href="/student/topics/<%= topic.id %>/practice" class="btn btn-primary btn-sm mt-1">Try Again</a>
  </div>
  <% } %>

  <% if (questions.length === 0) { %>
    <div class="alert alert-info">No questions available for this topic yet. Check back soon.</div>
  <% } else if (!results) { %>
  <!-- Practice Form -->
  <form method="POST" action="/student/topics/<%= topic.id %>/practice" id="practice-form">
    <% questions.forEach((q, i) => { %>
    <div class="card mb-2">
      <div class="flex-between mb-2">
        <span style="font-weight:700;color:var(--text)">Q<%= i+1 %>.</span>
        <div class="flex gap-1">
          <span class="tag <%= q.type==='mcq'?'tag-blue':q.type==='open'?'tag-orange':'tag-gray' %>">
            <%= q.type.toUpperCase() %>
          </span>
          <span class="tag tag-gray"><%= q.points || 10 %> pts</span>
        </div>
      </div>
      <p style="margin-bottom:1rem;font-size:.97rem;line-height:1.6"><%= q.text %></p>

      <% if (q.type === 'mcq' && q.options) { %>
        <% q.options.forEach(opt => { %>
        <label style="display:flex;align-items:center;gap:.6rem;padding:.45rem .6rem;border-radius:6px;cursor:pointer;margin-bottom:.3rem;border:1.5px solid var(--border);transition:.15s" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
          <input type="radio" name="question_<%= q.id %>" value="<%= opt %>" style="width:auto" /> <%= opt %>
        </label>
        <% }) %>

      <% } else if (q.type === 'tf') { %>
        <label style="display:flex;align-items:center;gap:.6rem;padding:.4rem .6rem;border-radius:6px;cursor:pointer;border:1.5px solid var(--border);margin-bottom:.3rem">
          <input type="radio" name="question_<%= q.id %>" value="true" style="width:auto" /> True
        </label>
        <label style="display:flex;align-items:center;gap:.6rem;padding:.4rem .6rem;border-radius:6px;cursor:pointer;border:1.5px solid var(--border)">
          <input type="radio" name="question_<%= q.id %>" value="false" style="width:auto" /> False
        </label>

      <% } else { %>
        <textarea name="question_<%= q.id %>" rows="4" placeholder="Type your answer here. Be specific and use technical terminology where appropriate..."></textarea>
        <small class="text-muted">This answer will be graded by Gemini AI using the topic rubric.</small>
      <% } %>
    </div>
    <% }) %>

    <button type="submit" class="btn btn-primary btn-lg" style="width:100%" id="submit-btn">
      Submit Answers
    </button>
  </form>

  <% } else { %>
  <!-- Results Display -->
  <% results.forEach((r, i) => { %>
  <div class="card mb-2 <%= r.correct ? 'result-correct' : r.score > 0 ? 'result-partial' : 'result-incorrect' %>">
    <div class="flex-between mb-1">
      <span style="font-weight:700">Q<%= i+1 %>. <%= r.question.text.substring(0, 80) %><%= r.question.text.length > 80 ? '...' : '' %></span>
      <span class="score-pill"><%= r.score %> / <%= r.maxScore %> pts</span>
    </div>
    <div style="font-size:.88rem;margin-bottom:.4rem">
      <strong>Your answer:</strong> <span style="color:var(--text-muted)"><%= r.studentAnswer || '(no answer)' %></span>
    </div>
    <div style="font-size:.9rem"><strong>Feedback:</strong> <%= r.feedback %></div>
    <% if (r.ai_feedback && r.ai_feedback.missing_concepts && r.ai_feedback.missing_concepts.length > 0) { %>
    <div style="font-size:.83rem;margin-top:.4rem;color:var(--warn)">
      <strong>Missing concepts:</strong> <%= r.ai_feedback.missing_concepts.join(', ') %>
    </div>
    <% } %>
  </div>
  <% }) %>
  <% } %>
</div>

<script>
document.getElementById('practice-form')?.addEventListener('submit', function(e) {
  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Grading… please wait';
  btn.disabled = true;
  btn.style.opacity = '.7';
});
</script>

<%- include('../partials/footer') %>
