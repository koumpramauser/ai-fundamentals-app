<%- include('../partials/header', { title: 'Pseudo-code Workspace' }) %>
<%- include('../partials/navbar') %>

<div class="page">
  <div class="flex-between mb-3">
    <div>
      <div class="page-title">Pseudo-code Workspace</div>
      <div class="page-sub">Write your algorithm logic and get instant AI feedback on structure and correctness.</div>
    </div>
    <a href="/student/dashboard" class="btn btn-outline btn-sm">← Dashboard</a>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start" class="workspace-grid">

    <!-- Editor Panel -->
    <div>
      <div class="card">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;color:var(--primary)">✏️ Editor</div>

        <% if (error) { %><div class="alert alert-error mb-2"><%= error %></div><% } %>

        <form method="POST" action="/student/workspace/review" id="ws-form">
          <div class="form-group">
            <label for="algorithmName">Algorithm / Concept</label>
            <select name="algorithmName" id="algorithmName">
              <option value="A* Search" <%= typeof algorithmName !== 'undefined' && algorithmName === 'A* Search' ? 'selected' : '' %>>A* Search</option>
              <option value="Gradient Descent" <%= typeof algorithmName !== 'undefined' && algorithmName === 'Gradient Descent' ? 'selected' : '' %>>Gradient Descent</option>
              <option value="Backpropagation" <%= typeof algorithmName !== 'undefined' && algorithmName === 'Backpropagation' ? 'selected' : '' %>>Backpropagation</option>
              <option value="BFS / DFS" <%= typeof algorithmName !== 'undefined' && algorithmName === 'BFS / DFS' ? 'selected' : '' %>>BFS / DFS</option>
              <option value="Minimax" <%= typeof algorithmName !== 'undefined' && algorithmName === 'Minimax' ? 'selected' : '' %>>Minimax</option>
              <option value="K-Means Clustering" <%= typeof algorithmName !== 'undefined' && algorithmName === 'K-Means Clustering' ? 'selected' : '' %>>K-Means Clustering</option>
              <option value="Naive Bayes" <%= typeof algorithmName !== 'undefined' && algorithmName === 'Naive Bayes' ? 'selected' : '' %>>Naive Bayes</option>
              <option value="General / Other" <%= typeof algorithmName !== 'undefined' && algorithmName === 'General / Other' ? 'selected' : '' %>>General / Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="pseudocode">Your Pseudo-code</label>
            <textarea
              id="pseudocode"
              name="pseudocode"
              rows="18"
              placeholder="Example (A* Search):

function A_Star(start, goal):
  open_list = priority queue
  add start to open_list with f = 0

  while open_list is not empty:
    current = node with lowest f in open_list
    if current == goal:
      return reconstruct_path(current)

    for each neighbor of current:
      g = current.g + edge_cost(current, neighbor)
      h = heuristic(neighbor, goal)
      f = g + h
      if neighbor not in open_list or g < neighbor.g:
        update neighbor: g, h, f, parent = current
        add neighbor to open_list

  return FAILURE"
              style="font-family:'Courier New',monospace;font-size:.88rem;line-height:1.6;background:#f8f9fc"
            ><%= typeof pseudocode !== 'undefined' ? pseudocode : '' %></textarea>
          </div>

          <button type="submit" class="btn btn-accent btn-lg" style="width:100%" id="review-btn">
            🤖 Request AI Review
          </button>
        </form>

        <div class="mt-2" style="font-size:.8rem;color:var(--text-muted);line-height:1.5">
          <strong>Tips:</strong> Use indentation to show structure. Label loops, conditions, and function calls clearly.
          Don't worry about syntax — this is about logic!
        </div>
      </div>
    </div>

    <!-- Review Panel -->
    <div>
      <div class="card" style="min-height:300px">
        <div style="font-weight:700;font-size:.95rem;margin-bottom:1rem;color:var(--primary)">🤖 AI Feedback</div>

        <% if (!review) { %>
          <div style="text-align:center;padding:3rem 1rem;color:var(--text-muted)">
            <div style="font-size:2.5rem;margin-bottom:.8rem">🧠</div>
            <div style="font-size:.95rem">Write your pseudo-code on the left, then click <strong>Request AI Review</strong> to receive detailed feedback from Gemini 2.0 Flash.</div>
          </div>
        <% } else { %>
          <div id="review-content" style="font-size:.9rem;line-height:1.7">
            <%- markdownToHtml(review) %>
          </div>
        <% } %>
      </div>

      <!-- Sample algorithms reference -->
      <div class="card mt-2" style="background:var(--surface2)">
        <div style="font-weight:700;font-size:.85rem;margin-bottom:.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px">Quick Reference</div>
        <ul style="font-size:.83rem;line-height:1.8;color:var(--text-muted);padding-left:1.2rem">
          <li><strong>A* Search:</strong> Uses f(n) = g(n) + h(n) with a priority queue</li>
          <li><strong>Gradient Descent:</strong> θ = θ - α ∇J(θ) at each iteration</li>
          <li><strong>BFS:</strong> FIFO queue, visits all nodes at depth d before d+1</li>
          <li><strong>Minimax:</strong> Alternates MAX/MIN layers, evaluates terminal states</li>
          <li><strong>Feature Extraction & Decision:</strong> Chain rule — propagate error from output to weights</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
@media (max-width: 780px) {
  .workspace-grid { grid-template-columns: 1fr !important; }
}
/* Markdown-rendered output styling */
#review-content h2 { font-family: var(--font-head); font-size: 1rem; color: var(--primary); margin: 1.1rem 0 .4rem; }
#review-content h3 { font-size: .93rem; font-weight: 700; margin: .9rem 0 .3rem; }
#review-content ul, #review-content ol { padding-left: 1.3rem; margin: .4rem 0; }
#review-content li { margin-bottom: .25rem; }
#review-content strong { color: var(--text); }
#review-content code { background: var(--surface2); padding: 1px 5px; border-radius: 4px; font-size: .85rem; }
#review-content hr { margin: .8rem 0; }
</style>

<script>
document.getElementById('ws-form')?.addEventListener('submit', function() {
  const btn = document.getElementById('review-btn');
  btn.textContent = '⏳ Analyzing…';
  btn.disabled = true;
  btn.style.opacity = '.7';
});
</script>

<%- include('../partials/footer') %>
