<%- include('../partials/header.ejs', { title: 'Dashboard' }) %>
<%- include('../partials/navbar.ejs') %>

<div class="page">
  <!-- Welcome Banner -->
  <div class="card mb-3" style="background:linear-gradient(120deg,#002F6C 0%,#1a4d99 100%);color:#fff;border:none">
    <div class="flex-between">
      <div>
        <% if (sessionUser) { %>
          <div style="font-family:var(--font-head);font-size:1.3rem;font-weight:700;margin-bottom:.2rem">Welcome back, <%= sessionUser.name.split(' ')[0] %>!</div>
          <div style="opacity:.85;font-size:.92rem">Keep learning and climb the leaderboard.</div>
        <% } else { %>
          <div style="font-family:var(--font-head);font-size:1.3rem;font-weight:700;margin-bottom:.2rem">Welcome to StudyAI — FAU!</div>
          <div style="opacity:.85;font-size:.92rem"><a href="/auth/register" style="color:#ffd47e;font-weight:700">Register</a> or <a href="/auth/login" style="color:#ffd47e;font-weight:700">Log in</a> to track your score and join the leaderboard.</div>
        <% } %>
      </div>
      <% if (sessionUser) { %>
      <div style="text-align:right">
        <div style="font-size:.8rem;opacity:.75;margin-bottom:.2rem">Your Total Score</div>
        <div style="font-size:2rem;font-weight:800"><%= score.total_points %> <span style="font-size:.9rem;opacity:.8">pts</span></div>
      </div>
      <% } %>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start" class="main-grid">
    <!-- Topics -->
    <div>
      <div class="section-title">Study Topics (<%= topics.length %>)</div>
      <% if (topics.length === 0) { %>
        <div class="alert alert-info">Your instructor hasn't added any topics yet. Check back soon!</div>
      <% } else { %>
      <div class="grid-2">
        <% topics.forEach((t, i) => { %>
        <div class="card" style="display:flex;flex-direction:column;gap:.75rem">
          <div>
            <div style="font-weight:700;font-size:1rem;color:var(--text);margin-bottom:.3rem"><%= t.title %></div>
            <p class="text-muted" style="font-size:.85rem;line-height:1.55"><%= t.summary_text ? t.summary_text.substring(0, 100) + '...' : 'Explore this topic.' %></p>
          </div>
          <% if (t.podcast_url) { %>
          <a href="<%= t.podcast_url %>" target="_blank" rel="noopener" style="font-size:.83rem;color:var(--accent);font-weight:600">🎙 Listen to Podcast</a>
          <% } %>
          <div class="flex gap-1" style="margin-top:auto">
            <a href="/student/topics/<%= t.id %>" class="btn btn-outline btn-sm">Read Summary</a>
            <a href="/student/topics/<%= t.id %>/practice" class="btn btn-accent btn-sm">Practice</a>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>

      <div class="section-title mt-3">Tools</div>
      <div class="card flex gap-2" style="flex-wrap:wrap">
        <a href="/student/workspace" class="btn btn-primary">🖊 Pseudo-code Workspace</a>
        <a href="/leaderboard" class="btn btn-outline">🏆 Full Leaderboard</a>
      </div>
    </div>

    <!-- Sidebar Leaderboard -->
    <div>
      <div class="section-title">Top 10 Students</div>
      <div class="card">
        <% if (leaderboard.length === 0) { %>
          <p class="text-muted" style="font-size:.88rem">No scores yet. Be the first!</p>
        <% } else { %>
          <% leaderboard.forEach((row, i) => { %>
          <div class="flex-between" style="padding:.45rem 0;border-bottom:1px solid var(--border)<%= i===leaderboard.length-1?';border:none':'' %>">
            <div class="flex gap-1">
              <span class="lb-rank <%= i===0?'gold':i===1?'silver':i===2?'bronze':'' %>" style="font-size:.9rem">#<%= i+1 %></span>
              <span style="font-size:.88rem;font-weight:<%= row.users?.id === sessionUser?.id ? '700' : '400' %>"><%= row.users?.name || 'Student' %></span>
              <% if (row.users?.id === sessionUser?.id) { %><span class="tag tag-blue" style="font-size:.68rem">You</span><% } %>
            </div>
            <span class="lb-points" style="font-size:.88rem"><%= row.total_points %></span>
          </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<style>
@media (max-width: 740px) {
  .main-grid { grid-template-columns: 1fr !important; }
}
</style>

<%- include('../partials/footer') %>
